  "description": "Real-time chat app backend using Node.js, TypeScript, Express, MongoDB, Socket.io",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js"
  },
